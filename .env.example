SECRET_KEY=change-me-to-a-random-secret-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Caminho do arquivo SQLite (opcional, padrão é dentro do container).
# No App Service, aponte para dentro de /home (armazenamento persistente)
# para o banco sobreviver a restarts/deploys. No Container Apps não há disco
# persistente por padrão — o banco é perdido a cada restart/redeploy.
# DB_PATH=/home/data/db.sqlite3

# Deploy enxuto: sem Redis/worker, as tasks do Celery rodam de forma síncrona.
CELERY_TASK_ALWAYS_EAGER=True
