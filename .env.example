SECRET_KEY=change-me-to-a-random-secret-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Caminho do arquivo SQLite (opcional, padrão é dentro do container).
# No Container Apps, deploy/azure-deploy.sh já define DB_PATH=/data/db.sqlite3
# apontando pro volume do Azure Files montado no app, então o banco sobrevive
# a restarts/redeploys/scale-to-zero. No App Service, aponte para dentro de
# /home (armazenamento persistente) pelo mesmo motivo.
# DB_PATH=/home/data/db.sqlite3

# Deploy enxuto: sem Redis/worker, as tasks do Celery rodam de forma síncrona.
CELERY_TASK_ALWAYS_EAGER=True
